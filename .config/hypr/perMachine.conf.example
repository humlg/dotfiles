#################
### VARIABLEA ###
#################

$lockScreen = swaylock -f -i /home/david/Pictures/Wallpapers/Purple/Astronaut_rocket.jpg

################
### MONITORS ###
################

# See https://wiki.hyprland.org/Configuring/Monitors/
monitor=,preferred,0x0,1.5
monitor=DP-1,1920x1080@100,1280x-300,1
monitor=DP-3,1920x1080@100,1280x-300,1
monitor=HDMI-A-1,preffered,auto,1,mirror,eDP-1
#unscale XWayland
xwayland {
  force_zero_scaling = true
}

# toolkit-specific scale
env = GDK_SCALE,1.5
